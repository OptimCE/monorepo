#Step 0 - Global configuration
DOMAIN=http://localhost

# Step 1 - Public application routing
APP_CORS_ALLOWED_ORIGIN=http://localhost
WEB_BASE_PATH=/
WEB_API_URL=/api

# Step 2 - Identity provider (Keycloak)
AUTH_REALM=optimce-realm
AUTH_INTERNAL_URL=http://keycloak:8080/keycloak
AUTH_CLIENT_SECRET=changeme_keycloak_admin_password
WEB_AUTH_URL=/keycloak
WEB_AUTH_CLIENT_ID=optimce-frontend
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=admin

# Step 3 - Database configuration
CRM_DB_PASSWORD=changeme_db_password
KEYCLOAK_DB_PASSWORD=changeme_keycloak_db_password

# Step 4 - Storage configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
STORAGE_BUCKET=crm-files
STORAGE_API_URL=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:8091

# Step 5 - OpenTelemetry
REMOTE_LOGGING=false
OTEL_EXPORTER_OTLP_ENDPOINT=none

# Step 6 - Reverse Proxy
USE_HTTPS=false
SSL_EMAIL=admin@example.com
DOMAIN_HOST=localhost
SSL_CERT_PATH=/etc/letsencrypt/live/localhost/fullchain.pem
SSL_CERT_KEY_PATH=/etc/letsencrypt/live/localhost/privkey.pem
